PORT=3000
HOST=0.0.0.0
NODE_ENV=production
FRONTEND_DIR=frontend
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173
FRONTEND_PORT=5173
FRONTEND_API_BASE=http://127.0.0.1:3000
S3_FRONTEND_BUCKET=
S3_FRONTEND_PREFIX=rag

ENABLE_GEMINI=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ENABLE_SEMANTIC_RAG=false
ENABLE_VECTOR_DB=false
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_CACHE_PATH=backend/data/embedding-cache.json
VECTOR_DB_TOP_K=5
RETRIEVAL_CANDIDATE_POOL=16
CONTEXT_MAX_CHARACTERS=5200
MAX_UPLOAD_BYTES=10485760
MAX_DOCUMENT_CHARACTERS=250000
RATE_LIMIT_WINDOW_MS=60000
ASK_RATE_LIMIT=30
AUTH_RATE_LIMIT=20
SEMANTIC_SIMILARITY_THRESHOLD=0.62
HYBRID_SEMANTIC_WEIGHT=0.65
HYBRID_KEYWORD_WEIGHT=0.35

ADMIN_USER=admin
ADMIN_PASSWORD_HASH=
REVIEWER_USER=reviewer
REVIEWER_PASSWORD_HASH=
VIEWER_USER=viewer
VIEWER_PASSWORD_HASH=

ENABLE_POSTGRES=false
DATABASE_URL=postgres://rag_user:rag_password@localhost:5432/rag_demo
DATABASE_SSL=false

OBJECT_STORAGE_DIR=backend/storage/objects
OBJECT_STORAGE_PROVIDER=local
AWS_REGION=us-east-1
S3_BUCKET=
S3_PREFIX=rag-demo/originals
OCR_ENABLED=false
TESSERACT_BIN=tesseract
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
