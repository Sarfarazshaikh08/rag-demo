NODE_ENV=production
PORT=3000
HOST=127.0.0.1

# Set this to your S3 website endpoint, CloudFront URL, or custom frontend domain.
CORS_ORIGIN=https://frontend.example.com

# Required for cross-origin cookie auth from S3/CloudFront to EC2 HTTPS backend.
SESSION_COOKIE_SAMESITE=None
SESSION_COOKIE_SECURE=true

ENABLE_GEMINI=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ENABLE_SEMANTIC_RAG=false
ENABLE_VECTOR_DB=false
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_CACHE_PATH=backend/data/embedding-cache.json
VECTOR_DB_TOP_K=5
RETRIEVAL_CANDIDATE_POOL=16
CONTEXT_MAX_CHARACTERS=5200
MAX_UPLOAD_BYTES=10485760
MAX_DOCUMENT_CHARACTERS=250000
RATE_LIMIT_WINDOW_MS=60000
ASK_RATE_LIMIT=30
AUTH_RATE_LIMIT=20
SEMANTIC_SIMILARITY_THRESHOLD=0.62
HYBRID_SEMANTIC_WEIGHT=0.65
HYBRID_KEYWORD_WEIGHT=0.35

ADMIN_USER=admin
ADMIN_PASSWORD_HASH=
REVIEWER_USER=reviewer
REVIEWER_PASSWORD_HASH=
VIEWER_USER=viewer
VIEWER_PASSWORD_HASH=

ENABLE_POSTGRES=false
DATABASE_URL=
DATABASE_SSL=false

OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_DIR=backend/storage/objects
AWS_REGION=us-east-1
S3_BUCKET=
S3_PREFIX=rag-demo/originals
OCR_ENABLED=false
TESSERACT_BIN=tesseract
